# Cortex memory system configuration
# Copy to your workspace root as .memory-config

# PARA directory defaults
daily_dir: 2-areas/me/daily
learnings: 2-areas/me/learnings.md
reflect_log: 2-areas/me/reflect-log.md
project_root: 1-projects

# Workspace isolation (separate concepts.db per workspace)
workspace: personal

# Concepts graph database path (default: concepts.db in workspace root)
# db_path: concepts.db

# Project definitions
# Maps project names to directory paths. Default: each unique parent directory = one project.
# Uncomment and customize for non-directory-based projects:
# projects:
#   cortex: 1-projects/memory/cortex
#   website: 1-projects/ved-website
#   strategy: 2-areas/me

# Sensitive session handling
# default_sensitive: false
